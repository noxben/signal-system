# --- Market hours (ET) ---
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
MARKET_TIMEZONE=America/New_York

# --- Signal engine thresholds (§6-8, do not tune until 60 signals) ---
VOLUME_SPIKE_MULTIPLIER=2.5
SCORE_PASS_THRESHOLD=5
PRICE_CHANGE_MAX_PCT=2.0
NO_NEWS_WINDOW_HOURS=4
SECTOR_ALIGN_WINDOW_MINUTES=60
REPEAT_SPIKE_WINDOW_HOURS=48
DUPLICATE_COOLDOWN_HOURS=24
DUPLICATE_SCORE_EXCEPTION=2

# --- Hard filter thresholds ---
EARNINGS_BUFFER_DAYS=7
MIN_MARKET_CAP=2000000000
MIN_AVG_DAILY_VOLUME=500000
LATE_ENTRY_PCT=5.0

# --- Paper trading ---
POSITION_SIZE_USD=1000
TAKE_PROFIT_PCT=5.0
STOP_LOSS_PCT=3.0
MAX_HOLD_DAYS=3

# --- Worker cadences (seconds) ---
MARKET_WORKER_INTERVAL=300
NEWS_WORKER_INTERVAL=900
POLITICAL_WORKER_INTERVAL=21600
SIGNAL_ENGINE_INTERVAL=300

# --- Health monitoring ---
HEALTH_DEGRADED_MULTIPLIER=2
HEALTH_WATCHDOG_MULTIPLIER=3
